matriz = [[1, 2], [3, 4], [5, 6]]
linhas = len(matriz)
colunas = len(matriz[0])
transposta = []
for x in range(colunas):
    nova_linha = []
    for i in range(linhas):
        nova_linha.append(matriz[i][x])
    transposta.append(nova_linha)

print("Matriz:")
for linha in matriz:
    print(linha)
print("\nTransposta:")
for linha in transposta:
    print(linha)
