while True:
    nome = input("Atleta: ")
    if nome == "":
        break

    notas = []
    for i in range(7):
        n = float(input("Nota: "))
        notas.append(n)

    melhor = max(notas)
    pior = min(notas)
    media = (sum(notas) - melhor - pior) / 5

    print("\nResultado final:")
    print(f"Atleta: {nome}")
    print(f"Melhor nota: {melhor}")
    print(f"Pior nota: {pior}")
    print(f"Média: {media:.2f}\n")
