matriz = [[67, 69, 68, 9, 3, 6, 180, 90, 360, 2, 4, 6656, 342, 54, 4, 9, 2006, 2006, 3, 3, 3, 9, 9, 9, 6, 6, 6, 2, 2, 2, 2, 13, 13, 13, 13, 13, 13]]
elemento = int(input("Insira o elemento: "))
cont = 0
for linha in matriz:
    for item in linha:
        if item == elemento:
            cont += 1
print(f"Elemento {elemento} aparece {cont} vezes na matriz.")
