intervalo1 = 0  
intervalo2 = 0
intervalo3 = 0  
intervalo4 = 0  

num = float(input("Digite um número positivo (ou negativo para finalizar): "))

while num >= 0:
    if num <= 25:
        intervalo1 += 1
    elif num <= 50:
        intervalo2 += 1
    elif num <= 75:
        intervalo3 += 1
    elif num <= 100:
        intervalo4 += 1
    
    num = float(input("Digite o próximo número: "))


print(f"\n[0-25]:   {intervalo1}")
print(f"\n[26-50]:  {intervalo2}")
print(f"\n[51-75]:  {intervalo3}")
print(f"\n[76-100]: {intervalo4}")
