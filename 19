text = input("Insira uma frase: ")
vogais = "aeiou"
total_vogais = 0
total_consoantes = 0
texto_limpo = text.lower()
for letra in texto_limpo:
    if letra.isalpha():
        if letra in vogais:
            total_vogais += 1
        else:
            total_consoantes += 1

print(f"Vogais: {total_vogais}")
print(f"Consoantes: {total_consoantes}")
